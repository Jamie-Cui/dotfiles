##########################################################################

# themes
include ./themes/zenburn.conf
# include ./themes/modus-vivendi.conf
# include ./themes/gruvbox-dark.conf

# shell config
# shell /bin/zsh

# terminal opacity and blur
# background_opacity 1
# background_blur 1

# advance
# term xterm-kitty

# terminal bell
enable_audio_bell no

allow_remote_control yes

listen_on unix:/tmp/mykitty

# os specific tweaks (Gnome window decoration for wayland)
# linux_display_server x11

# font
font_family        Maple Mono NL NF CN
bold_font          auto
italic_font        auto
bold_italic_font   auto
font_size @FONT_SIZE@
